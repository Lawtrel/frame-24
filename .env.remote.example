# Copie este arquivo para .env.remote
# Opção A: SSH Tunnel (seguro) -> use host.docker.internal nas variáveis *_HOST
# Opção B: Portas expostas no firewall -> use o IP público 174.138.79.19

# ========== INFRASTRUCTURE (VPS 174.138.79.19) ==========
# PostgreSQL
REMOTE_DATABASE_URL=postgresql://frame24:frame24pass@174.138.79.19:5432/frame24?schema=public&connection_limit=30

# Redis
REMOTE_REDIS_HOST=174.138.79.19
REMOTE_REDIS_PORT=6379
REMOTE_REDIS_PASSWORD=frame24redis

# RabbitMQ
REMOTE_RABBITMQ_HOST=174.138.79.19
REMOTE_RABBITMQ_PORT=5672
REMOTE_RABBITMQ_PASSWORD=frame24pass

# MinIO / S3
REMOTE_MINIO_ENDPOINT=174.138.79.19
REMOTE_MINIO_PORT=9000
REMOTE_MINIO_ACCESS_KEY=frame24-storage-key
REMOTE_MINIO_SECRET_KEY=frame24-storage-secret-2026
REMOTE_STORAGE_PUBLIC_URL=http://174.138.79.19:9000

# ========== AUTH / SECRETS (VALORES REAIS DA VPS /opt/frame24/.env) ==========
REMOTE_JWT_SECRET=frame24-prod-jwt-secret-2026-change-me
REMOTE_BETTER_AUTH_SECRET=frame24-prod-better-auth-secret-2026-change-me
REMOTE_AUTH_INTERNAL_SECRET=frame24-prod-auth-internal-secret-2026
REMOTE_OIDC_INTERNAL_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ========== TENANT / DOMAIN ==========
REMOTE_TENANT_BASE_DOMAIN=lawtrel.dev
REMOTE_BETTER_AUTH_URL=https://api.lawtrel.dev
REMOTE_API_URL=https://api.lawtrel.dev
REMOTE_FRONTEND_URL=https://lawtrel.dev,https://www.lawtrel.dev,https://admin.lawtrel.dev,https://api.lawtrel.dev,https://app.lawtrel.dev
REMOTE_NEXT_PUBLIC_API_URL=https://lawtrel.dev
REMOTE_NEXT_PUBLIC_SOCKET_URL=https://lawtrel.dev
REMOTE_NEXT_PUBLIC_AUTH_URL=https://lawtrel.dev
REMOTE_NEXT_PUBLIC_TMDB_API_KEY=b7626214ac55a24c995e552f7940ee24