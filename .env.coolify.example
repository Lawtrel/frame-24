# Image publicada pela GitHub Actions (GHCR)
API_IMAGE=ghcr.io/lawtrel/frame-24-api:latest

# API
NODE_ENV=production
PORT=4000
# Porta publicada no host (mantem 4000 no container)
API_HOST_PORT=4000
API_URL=https://api.seu-dominio.com
FRONTEND_URL=https://seu-web.vercel.app,https://seu-admin.vercel.app,https://seu-landing.vercel.app

# Database (Postgres no mesmo compose)
POSTGRES_USER=frame24
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=frame24
# Porta publicada no host para acesso externo/ops
POSTGRES_HOST_PORT=5432
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_EFFECTIVE_CACHE_SIZE=192MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_RANDOM_PAGE_COST=1.1
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_WAL_COMPRESSION=on
POSTGRES_MAX_WAL_SIZE=1GB
POSTGRES_MIN_WAL_SIZE=80MB
POSTGRES_AUTOVACUUM=on
POSTGRES_AUTOVACUUM_NAPTIME=10s
POSTGRES_LOG_MIN_DURATION_STATEMENT=500
POSTGRES_LOG_CHECKPOINTS=on
POSTGRES_LOG_CONNECTIONS=off
POSTGRES_LOG_DISCONNECTIONS=off
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/frame24?schema=public&connection_limit=30
DIRECT_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/frame24?schema=public&connection_limit=30

# Redis externo
REDIS_URL=redis://<REDIS_USER>:<REDIS_PASSWORD>@redis.externo.com:6379
REDIS_HOST=redis.externo.com
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ externo
RABBITMQ_URI=amqp://<RABBITMQ_USER>:<RABBITMQ_PASSWORD>@rabbit.externo.com:5672
RABBITMQ_HOST=rabbit.externo.com
RABBITMQ_PORT=5672
RABBITMQ_USER=<RABBITMQ_USER>
RABBITMQ_PASSWORD=<RABBITMQ_PASSWORD>

# MinIO no mesmo VPS (compose)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
# Portas publicadas no host
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>
MINIO_USE_SSL=false
MINIO_BUCKET=frame24-uploads
MINIO_REGION=us-east-1
# URL publica do storage/CDN (fallback do STORAGE_PUBLIC_URL)
MINIO_PUBLIC_URL=https://storage.seu-dominio.com
STORAGE_PUBLIC_URL=https://storage.seu-dominio.com

# Auth
JWT_SECRET=<JWT_SECRET_MIN_32_CHARS>
JWT_AUDIENCE=frame24-api
JWT_ISSUER=frame24-api
JWT_EXPIRES_IN=8h
BETTER_AUTH_SECRET=<BETTER_AUTH_SECRET_MIN_32_CHARS>
# Se vazio, a API usa API_URL automaticamente
BETTER_AUTH_URL=https://api.seu-dominio.com

# Email
EMAIL_FROM=noreply@seu-dominio.com
RESEND_API_KEY=

WORKER_ID=1
