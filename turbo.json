{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env*", ".editorconfig", ".prettierrc.json", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "PORT",
    "DATABASE_URL",
    "DIRECT_URL",
    "FRONTEND_URL",
    "TENANT_BASE_DOMAIN",
    "API_URL",
    "JWT_SECRET",
    "WORKER_ID",
    "RABBITMQ_*",
    "MINIO_*",
    "STORAGE_PUBLIC_URL",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "PLAYWRIGHT_BASE_URL",
    "E2E_TENANT_SLUG",
    "E2E_CITY_SLUG",
    "E2E_MOVIE_SLUG",
    "E2E_CHECKOUT_ID",
    "E2E_ORDER_ID",
    "E2E_CUSTOMER_EMAIL",
    "E2E_CUSTOMER_PASSWORD"
  ],
  "tasks": {
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true,
      "env": ["NEXT_PUBLIC_*"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "db:generate": {
      "cache": false,
      "env": ["DATABASE_URL", "DIRECT_URL"]
    },
    "db:migrate": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "DIRECT_URL"]
    },
    "db:deploy": {
      "cache": false,
      "env": ["DATABASE_URL", "DIRECT_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    }
  }
}
