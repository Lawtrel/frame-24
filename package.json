{
  "name": "frame-24",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:admin": "turbo run dev --filter=admin",
    "lint": "turbo run lint",
    "lint:strict": "pnpm --filter web run lint:strict && pnpm --filter admin run lint:strict",
    "lint:strict:web": "pnpm --filter web run lint:strict",
    "lint:strict:admin": "pnpm --filter admin run lint:strict",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "eslint": "9.39.1",
      "@eslint/js": "9.39.1",
      "class-validator": "0.14.2",
      "cross-spawn": "7.0.5",
      "glob": "10.5.0",
      "lodash": "4.18.0",
      "minimatch": "9.0.7",
      "path-to-regexp": "8.4.0",
      "picomatch": "4.0.4",
      "tar": "7.5.11"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
